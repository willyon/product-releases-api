# product-releases-api 环境变量示例（复制为 .env，勿提交 Git）
#
# 两大块：STATS_*（下载站统计页） + LICENSE_* / EMAIL_*（桌面端许可证）

# 监听地址（默认仅本机）
HOST=127.0.0.1
# 本地 npm run dev 默认 3091（见 server.js）；与宿主机 Docker 3090 错开。容器内仍用 compose 的 PORT=3090。
PORT=3091

# SQLite 数据库文件路径（相对项目根目录）
DB_PATH=./data/product-releases.db

# 开发环境允许的前端 Origin（逗号分隔）；生产环境若需跨域可设置 STATS_CORS_ORIGINS
# STATS_CORS_ORIGINS=http://127.0.0.1:5174

# 查看统计接口鉴权（登录用户名密码 + JWT；对外公开的 page-view/download 上报不需登录）
STATS_ADMIN_USERNAME=admin
STATS_ADMIN_PASSWORD=change-me
# 至少 16 字符随机串，用于签发 Bearer Token
STATS_JWT_SECRET=please_replace_with_a_long_random_string_at_least_16_chars
# 可选，默认 8h
# STATS_JWT_EXPIRES_IN=8h

# ----- 许可证 API（云端 / 桌面端调用）-----
# 163 邮箱示例：EMAIL_HOST=smtp.163.com EMAIL_PORT=465
# EMAIL_USER=your_noreply@163.com
# EMAIL_PASS=your_smtp_authorization_code
# 运行 node scripts/license-generate-keys.js 后填入（勿提交 Git）
# LICENSE_PRIVATE_KEY_BASE64=
# LICENSE_PUBLIC_KEY_BASE64=  # 仅桌面端验签与备份；服务端签名只需私钥
# LICENSE_ADMIN_SECRET=
# LICENSE_TRIAL_DAYS=14
# LICENSE_DEVICE_LIMIT=2
# LICENSE_SEND_CODE_COOLDOWN_SECONDS=60
# LICENSE_VERIFICATION_TTL_MINUTES=10
# LICENSE_CODE_PEPPER=change-me-in-production
# 桌面端 Origin 白名单（可选；无 Origin 的请求始终放行，便于 Electron）
# LICENSE_CORS_ORIGINS=http://127.0.0.1:5173
