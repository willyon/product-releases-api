# 监听地址（默认仅本机）
HOST=127.0.0.1
# 本地 npm run dev 默认 3091（见 server.js）；与宿主机 Docker 3090 错开。容器内仍用 compose 的 PORT=3090。
PORT=3091

# SQLite 数据库文件路径（相对项目根目录）
STATS_DB_PATH=./data/stats.db

# 开发环境允许的前端 Origin（逗号分隔）；生产环境若需跨域可设置 STATS_CORS_ORIGINS
# STATS_CORS_ORIGINS=http://127.0.0.1:5173

# 查看统计接口鉴权（登录用户名密码 + JWT；对外公开的 page-view/download 上报不需登录）
STATS_ADMIN_USERNAME=admin
STATS_ADMIN_PASSWORD=change-me
# 至少 16 字符随机串，用于签发 Bearer Token
STATS_JWT_SECRET=please_replace_with_a_long_random_string_at_least_16_chars
# 可选，默认 8h
# STATS_JWT_EXPIRES_IN=8h
